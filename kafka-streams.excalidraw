    {
      "type": "text",
      "id": "code_text",
      "x": 76, "y": 682,
      "width": 628, "height": 212,
      "text": "StreamsBuilder builder = new StreamsBuilder();\n\nKStream<String, Order> orders = builder.stream(\"topic-orders\");\nKTable<String, User>  users  = builder.table(\"topic-users\");\n\norders.filter((k, v) -> v.amount > 100)\n      .to(\"sink-filtered\");\n\norders.map((k, v) -> KeyValue.pair(k, v.toJson()))\n      .to(\"sink-mapped\");\n\norders.groupByKey().count()\n      .toStream().to(\"sink-counts\");\n\norders.join(users, (o, u) -> enrich(o, u))\n      .to(\"sink-enriched\");",
      "originalText": "StreamsBuilder builder = new StreamsBuilder();\n\nKStream<String, Order> orders = builder.stream(\"topic-orders\");\nKTable<String, User>  users  = builder.table(\"topic-users\");\n\norders.filter((k, v) -> v.amount > 100)\n      .to(\"sink-filtered\");\n\norders.map((k, v) -> KeyValue.pair(k, v.toJson()))\n      .to(\"sink-mapped\");\n\norders.groupByKey().count()\n      .toStream().to(\"sink-counts\");\n\norders.join(users, (o, u) -> enrich(o, u))\n      .to(\"sink-enriched\");",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
